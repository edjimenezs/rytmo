// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION MODELS
// ============================================

enum UserRole {
  ATHLETE
  COACH
  NUTRITIONIST
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String?
  image         String?
  role          UserRole  @default(ATHLETE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts             Account[]
  sessions             Session[]
  profile              Profile?
  medicalDocuments     MedicalDocument[]
  trainingActivities   TrainingActivity[]
  manualEntries        ManualTrainingEntry[]
  dailyCheckins        DailyCheckin[]
  dailyRecommendations DailyRecommendation[]
  dailyFeedback        DailyFeedback[]

  // As athlete
  coaches       CoachAthlete[]       @relation("AthleteCoaches")
  nutritionists NutritionistClient[] @relation("ClientNutritionists")

  // As coach
  athletes   CoachAthlete[] @relation("CoachAthletes")
  coachNotes CoachNote[]

  // As nutritionist
  clients        NutritionistClient[] @relation("NutritionistClients")
  nutritionNotes NutritionNote[]

  // Strava integration
  stravaIntegration StravaIntegration?
  trainingPlanEntries TrainingPlanEntry[] @relation("UserTrainingPlanEntries")
  trainingPeaksIntegration TrainingPeaksIntegration?
  garminIntegration GarminIntegration?

  @@index([email])
  @@index([role])
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal info
  dateOfBirth DateTime?
  gender      String?
  height      Float? // in cm
  weight      Float? // in kg
  phone       String?

  // Sports info
  sportType       String? // e.g., "Running", "Cycling", "Triathlon"
  experienceLevel String? // e.g., "Beginner", "Intermediate", "Advanced"
  goals           String? // Text description of goals

  // Performance & location
  ftp         Int?    // Functional Threshold Power (watts)
  timezone    String? // IANA timezone (e.g., "America/Santiago")
  location    String? // Free-text location

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// MEDICAL DATA MODELS
// ============================================

enum DocumentType {
  LAB_RESULT
  IMAGING
  PRESCRIPTION
  MEDICAL_REPORT
  OTHER
}

model MedicalDocument {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  type        DocumentType
  fileUrl     String // S3 or storage URL
  fileName    String
  fileSize    Int // in bytes
  mimeType    String

  // Metadata
  testDate   DateTime? // Date the test/exam was performed
  uploadedAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Analysis
  extractedText String?    @db.Text // Extracted text from PDF/image
  processed     Boolean    @default(false) // Whether document has been processed
  labValues     LabValue[] // Extracted lab values

  @@index([userId])
  @@index([type])
  @@index([testDate])
  @@index([processed])
}

// Extracted lab values from medical documents
model LabValue {
  id         String          @id @default(cuid())
  documentId String
  document   MedicalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String

  // Lab test information
  testName       String // e.g., "Hemoglobina", "Glucosa", "Colesterol Total"
  value          Float // Numeric value
  unit           String? // e.g., "g/dL", "mg/dL", "mmol/L"
  referenceRange String? // e.g., "12.0-16.0 g/dL"
  status         String? // "NORMAL", "ALTO", "BAJO", "CRÍTICO"
  testDate       DateTime? // Date from the document

  // Metadata
  extractedAt DateTime @default(now())

  @@index([documentId])
  @@index([userId])
  @@index([testName])
  @@index([testDate])
}

// ============================================
// TRAINING DATA MODELS
// ============================================

enum ActivityType {
  RUNNING
  CYCLING
  SWIMMING
  WALKING
  WEIGHTLIFTING
  YOGA
  OTHER
}

enum ActivitySource {
  MANUAL
  STRAVA
  TRAINING_PEAKS
  OTHER_APP
  GARMIN
}

// Generic training activity (from any source)
model TrainingActivity {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Activity details
  name       String
  type       ActivityType
  source     ActivitySource @default(MANUAL)
  externalId String? // ID from external service (e.g., Strava)

  // Metrics
  distance         Float? // in meters
  duration         Int? // in seconds
  elevation        Float? // in meters
  calories         Int?
  averageHeartRate Int?
  maxHeartRate     Int?
  averagePace      Float? // in min/km

  // Timing
  startDate DateTime
  endDate   DateTime?

  // Additional data
  description String?
  notes       String?

  trainingPlanMatches TrainingPlanEntry[] @relation("TrainingPlanMatches")
  dailyRecommendations DailyRecommendation[] @relation("TrainingActivityDailyRecommendations")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([startDate])
  @@index([type])
  @@index([source])
  @@index([externalId])
  @@unique([userId, externalId, source])
}

model TrainingPlanEntry {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation("UserTrainingPlanEntries", fields: [userId], references: [id], onDelete: Cascade)
  date              DateTime
  sessionType       String
  title             String
  durationMinutes   Float?
  distanceKm        Float?
  tss               Float?
  notes             String?
  matchedActivityId String?
  matchedActivity   TrainingActivity?  @relation("TrainingPlanMatches", fields: [matchedActivityId], references: [id])
  dayType           String             @default("rest")
  requiresIntraFuel Boolean            @default(false)
  focus             String?
  dailyRecommendations DailyRecommendation[] @relation("PlanEntryDailyRecommendations")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@unique([userId, date, sessionType])
}

// Manual training entries (before Strava sync)
model ManualTrainingEntry {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  type      ActivityType
  date      DateTime
  duration  Int? // in minutes
  distance  Float? // in km
  intensity String? // "Low", "Medium", "High"
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

// ============================================
// STRAVA INTEGRATION
// ============================================

model StravaIntegration {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stravaUserId String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String

  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model TrainingPeaksIntegration {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalUserId String
  accessToken    String
  refreshToken   String
  expiresAt      DateTime
  lastSyncAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model GarminIntegration {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalUserId String
  accessToken    String
  refreshToken   String
  expiresAt      DateTime
  lastSyncAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================
// COACH-ATHLETE RELATIONSHIPS
// ============================================

enum RelationshipStatus {
  PENDING
  ACTIVE
  INACTIVE
}

model CoachAthlete {
  id        String @id @default(cuid())
  coachId   String
  coach     User   @relation("CoachAthletes", fields: [coachId], references: [id], onDelete: Cascade)
  athleteId String
  athlete   User   @relation("AthleteCoaches", fields: [athleteId], references: [id], onDelete: Cascade)

  status RelationshipStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([coachId, athleteId])
  @@index([coachId])
  @@index([athleteId])
  @@index([status])
}

model CoachNote {
  id        String @id @default(cuid())
  coachId   String
  coach     User   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  athleteId String

  title     String
  content   String  @db.Text
  isPrivate Boolean @default(false) // Private notes only coach can see

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
  @@index([athleteId])
  @@index([createdAt])
}

// ============================================
// NUTRITIONIST-CLIENT RELATIONSHIPS
// ============================================

model NutritionistClient {
  id             String @id @default(cuid())
  nutritionistId String
  nutritionist   User   @relation("NutritionistClients", fields: [nutritionistId], references: [id], onDelete: Cascade)
  clientId       String
  client         User   @relation("ClientNutritionists", fields: [clientId], references: [id], onDelete: Cascade)

  status RelationshipStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nutritionistId, clientId])
  @@index([nutritionistId])
  @@index([clientId])
  @@index([status])
}

model NutritionNote {
  id             String @id @default(cuid())
  nutritionistId String
  nutritionist   User   @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)
  clientId       String

  title     String
  content   String  @db.Text
  isPrivate Boolean @default(false) // Private notes only nutritionist can see

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nutritionistId])
  @@index([clientId])
  @@index([createdAt])
}

model FoodItem {
  id        String   @id @default(cuid())
  name      String
  category  String
  carbs     Float
  protein   Float
  fat       Float
  kcal      Float
  portion   String
  isQuick   Boolean  @default(false)
  isLight   Boolean  @default(false)
  isPre     Boolean  @default(false)
  isPost    Boolean  @default(false)
  isIntra   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DailyCheckin {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime
  sleepHours   Float?
  sleepQuality Int?
  fatigue      Int?
  hunger       Int?
  stress       Int?
  trainingType String?
  durationMin  Int?
  intensity    String?
  timeOfDay    String?
  notes        String?
  createdAt    DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model DailyRecommendation {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  summary        String   @db.Text
  breakfast      String?  @db.Text
  preWorkout     String?  @db.Text
  preWorkoutFoods Json?
  intraWorkout   String?  @db.Text
  intraWorkoutFoods Json?
  postWorkout    String?  @db.Text
  postWorkoutFoods Json?
  lunch          String?  @db.Text
  snack          String?  @db.Text
  dinner         String?  @db.Text
  dinnerFoods Json?
  rationale      String?  @db.Text
  foodReferences String?  @db.Text
  reasoning      String?  @db.Text
  dayType        String?
  focus          String?
  planEntryId    String?
  planEntry      TrainingPlanEntry? @relation("PlanEntryDailyRecommendations", fields: [planEntryId], references: [id])
  trainingActivityId String?
  trainingActivity   TrainingActivity? @relation("TrainingActivityDailyRecommendations", fields: [trainingActivityId], references: [id])
  atl            Float?
  ctl            Float?
  acwr           Float?
  createdAt      DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model DailyFeedback {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  energy      Int?
  hunger      Int?
  performance Int?
  digestion   Int?
  notes       String?
  createdAt   DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}
